# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=
SUPABASE_SERVICE_ROLE_KEY=

# Resource storage mode:
# - auto (default): use DO Spaces if any DO_SPACES_* vars are present, otherwise Supabase
# - do-spaces: force DO Spaces for resource uploads/downloads
# - supabase: force Supabase Storage for resource uploads/downloads
RESOURCE_STORAGE_MODE=auto

# Optional: DigitalOcean Spaces for resource files.
# If these are all set, uploads/downloads will use Spaces instead of Supabase Storage.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=

# Emergency-only toggle if magic-link emails are throttled.
# Set to true to bypass member auth checks temporarily, then set back to false.
ALLOW_MEMBER_BYPASS=false
ALLOW_ADMIN_BYPASS=false
BYPASS_MEMBER_EMAIL=admin@npestudyclub.online
