# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=
SUPABASE_SERVICE_ROLE_KEY=

# Emergency-only toggle if magic-link emails are throttled.
# Set to true to bypass member auth checks temporarily, then set back to false.
ALLOW_MEMBER_BYPASS=false
ALLOW_ADMIN_BYPASS=false
BYPASS_MEMBER_EMAIL=admin@npestudyclub.online
